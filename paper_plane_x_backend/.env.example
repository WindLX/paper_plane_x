# Optional: choose a custom TOML config file.
# If not set, backend uses config/default.toml
PPX_CONFIG_FILE=./config/example.local.toml

# Required for real model calls.
# Nested env override is enabled with '__'.
LLM__API_KEY=

# Optional overrides
# LLM__MODEL=deepseek-chat
# LLM__BASE_URL=https://api.deepseek.com/v1
# AGENT_LLM__EXTRACTION__MODEL=deepseek-chat
# AGENT_LLM__FACT_CHECK__MODEL=deepseek-chat
